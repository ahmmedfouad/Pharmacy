# Git LFS Configuration
# Only track example images with Git LFS (excluded from Vercel deployment)
# Source images needed for build must be regular git files

# Track example images with LFS
examples/*.jpg filter=lfs diff=lfs merge=lfs -text
examples/*.jpeg filter=lfs diff=lfs merge=lfs -text
examples/*.png filter=lfs diff=lfs merge=lfs -text
examples/*.gif filter=lfs diff=lfs merge=lfs -text

# Do NOT track src/ images with LFS - they're needed for build
# src/**/*.png
# src/**/*.jpg
# src/**/*.ico
